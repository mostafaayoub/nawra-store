# Copy this to .env on the server and fill in real values.
# Never commit the real .env file to git.
#
# Gmail SMTP — required for order confirmation emails.
# Create an App Password at https://myaccount.google.com/apppasswords
# (the password is 16 chars displayed as 4 groups; spaces are fine, the
#  server strips them).
GMAIL_USER=your-store@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
